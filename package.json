{
  "name": "knightcode",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:cli": "bun run --watch packages/cli/src/index.tsx",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build:cli": "bun run scripts/build.ts --single",
    "link:cli": "bun run build:cli && cd packages/cli && bun link",
    "ci:version": "changeset version && bun install",
    "ci:publish": "bun run scripts/pack-test.ts && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
